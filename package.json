{
  "name": "hyperframeset",
  "version": "1.0.0",
  "description": "HyperFrameset =============",
  "main": "HyperFrameset.js",
  "directories": {
    "doc": "doc",
    "test": "demo"
  },
  "scripts": {
    "test": "vitest run --browser && npx playwright test",
    "test:chrome": "vitest run --browser --browser.name=chromium",
    "test:firefox": "vitest run --browser --browser.name=firefox",
    "test:safari": "vitest run --browser --browser.name=webkit",
    "test:e2e": "npx playwright test",
    "build": "rollup -c",
    "demo": "node server.js",
    "demo:stop": "pkill -f 'node server.js' || echo 'No demo server running'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitest/browser": "^4.1.2",
    "@vitest/browser-playwright": "^4.1.2",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "playwright": "^1.59.1",
    "rollup": "^4.0.0",
    "vitest": "^4.1.2"
  }
}
